/*
========================================================================================
    Nextflow config file for running tests
========================================================================================
*/

// Force Conda ON and Docker OFF for these tests
conda.enabled = true
docker.enabled = true

executor {
    queueSize = 2
}

profiles {
    test {
        process.executor = 'local'
        // Other test-specific settings
    }
    azurebatch {
        includeConfig "$projectDir/conf/azurebatch.config"
        // Your Azure Batch settings
    }
}




process {
    maxCpus = 1
    maxMemory = '4 GB'

    withName: '.*' {
        cpus   = 1
        memory = 4.GB
        time   = 2.h
    }

    // SRA download process specifications
    withName: 'AWS_DOWNLOAD' {
        cpus = 1
        memory = '2 GB'
    }

    withName: 'FASTERQ_DUMP' {
        cpus = 2
        memory = '2 GB'
    }
}

params {
    // Base parameters from your existing config
    input    = "$projectDir/assets/samplesheet-test-local.csv"
    outdir   = "$projectDir/test-out"
    project  = "test"
    
    singleEnd = false
    mergeReads = false
    nreads = 10000
    
    // // Container configurations
    // // Note: These are commented out since they are hosted on Azure.
    // docker_container_metaphlan = "gutzcontainers.azurecr.io/metaphlan:4.1.0"
    // docker_container_multiqc = "gutzcontainers.azurecr.io/multiqc:1.11"
    // docker_container_fastp = "gutzcontainers.azurecr.io/fastp:0.23.4"
    // docker_container_aws = "gutzcontainers.azurecr.io/aws-cli-bash:ubuntu"
    // docker_container_sra = "gutzcontainers.azurecr.io/sra-tools-bash:latest"

    // AWS config
    aws_region = 'us-east-2'
    
    // Database paths
    direct_metaphlan_id = "mpa_vJan21_TOY_CHOCOPhlAnSGB_202103"
    direct_metaphlan_db = "$projectDir/assets/test_dbs/mp4_test_db/"
    direct_bt2options   = "very-sensitive"
    humann_bt2options   = "very-sensitive"

    humann_chocophlan = "$projectDir/assets/test_dbs/chocophlan"
    humann_uniref = "$projectDir/assets/test_dbs/uniref"
    humann_utilitymap = "$projectDir/assets/test_dbs/utility_mapping_test"

    // HUMAnN parameters
    humann_extraparams = "--bypass-nucleotide-search"

    // SRA download settings
    max_retry_count = 3
    max_parallel_downloads = 3
}

// Disable execution reports
timeline.enabled = false
report.enabled = false
trace.enabled = false
dag.enabled = false

cleanup = true