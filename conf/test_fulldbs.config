// Extends test profile with full local DBs. Toggle enable_medi to test with/without MEDI.
// Run: nextflow run main.nf -profile test_fulldbs
//
// All DBs served from local SSD scratch (/mnt/scratch/ssddbs), synced from
// s3://cjb-gutz-s3-demo per colin_notes_vm.md section 4.

includeConfig 'test.config'

workDir = '/mnt/scratch/work'
executor {
    queueSize = 20
}
process {
    withName: 'profile_taxa' {
        cpus   = 8
        memory = 38.GB
    }
    withName: 'profile_function' {
        cpus   = 8
        memory = 60.GB
    }
    withName: 'MEDI_QUANT:kraken' {
        cpus          = 8
        maxForks      = 2
        time          = 30.m
        errorStrategy = { task.attempt < 2 ? 'retry' : 'ignore' }
        maxRetries    = 1
        beforeScript  = 'cat /mnt/scratch/ssddbs/medi_db/hash.k2d > /dev/null'
    }
}

params {
    outdir         = 's3://gutz-nf-reads-profilers-runs/results'
    project        = 'smoke-medi-test'
    input          = "$projectDir/assets/samplesheet-smoke-child.csv"
    nreads         = 0 // override test.config nreads for full profiling
    skipCompleted  = true // skip samples where HUMAnN + MEDI per-sample outputs already exist
    enable_medi    = true
    skipHumann     = false

    // MetaPhlAn + HUMAnN DBs — local SSD scratch
    direct_metaphlan_id    = "mpa_vJan25_CHOCOPhlAnSGB_202503"
    direct_metaphlan_db    = "/mnt/scratch/ssddbs/metaphlan_databases/vJan25/"
    humann_metaphlan_id    = "mpa_vOct22_CHOCOPhlAnSGB_202403"
    humann_metaphlan_db    = "/mnt/scratch/ssddbs/metaphlan_databases/vOct22/"
    humann_chocophlan      = "/mnt/scratch/ssddbs/chocophlan_v4_alpha/"
    humann_uniref          = "/mnt/scratch/ssddbs/uniref90_annotated_v4_alpha_ec_filtered/"
    humann_utilitymap      = "/mnt/scratch/ssddbs/full_mapping_v4_alpha/"

    // MEDI DBs — local SSD scratch
    medi_db_path       = '/mnt/scratch/ssddbs/medi_db/'
    medi_food_matches  = '/mnt/scratch/ssddbs/medi_db/food_matches.csv'
    medi_food_contents = '/mnt/scratch/ssddbs/medi_db/food_contents.csv.gz'

    // test.config sets --bypass-translated-search; override here so MEDI gets unaligned reads.
    humann_extraparams = ""
}

// Re-enable reports (test.config disables them)
report.enabled = true
trace.enabled  = true

// Keep work dir for inspection
cleanup = false
