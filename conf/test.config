executor {
    queueSize = 2         // Limit the total number of concurrent processes
}
process {
    withName: '.*' {
        // cpu = nope. Overwriting globally causes other problems.
        memory = 8.GB
        time   = 3.h
    }
    // Local Docker only: map container UID/GID to host so output files aren't
    // root-owned. AWS Batch rejects this — keep here, not in the module.
    withName: 'profile_function|profile_taxa|combine_humann_tables|convert_tables_to_biom|split_stratified_tables|regroup_genefamilies' {
        containerOptions = '-u $(id -u):$(id -g)'
    }
}

params {
    // Required parameters
    input    = "$projectDir/assets/samplesheet-test-local.csv"
    outdir   = "$projectDir/test-out"
    project  = "test"
    
    // Test data settings
    singleEnd = false
    mergeReads = false
    skipHumann = false

    // Minimize data for testing
    nreads = 10000
    minreads = 100   // Very low threshold for testing
    
    // Enable processing for testing new workflow
    humann_regroup    = true
    humann_split_size = 2  // Small split size for testing

    // Test database paths
    direct_metaphlan_id = "mpa_vJan21_TOY_CHOCOPhlAnSGB_202103"
    humann_metaphlan_id = "mpa_vJan21_TOY_CHOCOPhlAnSGB_202103"
    direct_metaphlan_db = "$projectDir/assets/test_dbs/mp4_test_db/"
    direct_bt2options   = "very-sensitive"
    humann_bt2options   = "very-sensitive"
    humann_metaphlan_db = "$projectDir/assets/test_dbs/mp4_test_db/"
    
    humann_chocophlan = "$projectDir/assets/test_dbs/chocophlan"
    humann_uniref = "$projectDir/assets/test_dbs/uniref"
    humann_utilitymap = "$projectDir/assets/test_dbs/utility_mapping_test"
    
    // Additional command line parameters
    humann_extraparams = "--bypass-translated-search"
    
    // MEDI quantification parameters (disabled by default for tests)
    enable_medi = false
    medi_db_path = null
    medi_food_matches = null
    medi_food_contents = null
    confidence = 0.3
    consistency = 0.95
    entropy = 0.1
    multiplicity = 4
    mapping = false
    read_length = 150
    threshold = 10
    batchsize = 10  // Smaller batch size for testing
}

// Disable execution reports for tests
timeline.enabled = false
report.enabled = false
trace.enabled = false
dag.enabled = false

// Clean work directory
cleanup = true


