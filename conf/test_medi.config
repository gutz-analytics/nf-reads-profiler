// Extends test profile to exercise the MEDI shortcut (I13).
// Run: nextflow run main.nf -profile test_medi
//
// What this tests:
//   1. HUMAnN adds --remove-temp-output false and emits *_unaligned.fa.gz
//   2. Unaligned reads are routed to Kraken2 in MEDI_QUANT (no fastp step)
//
// Requires: MEDI DB at the paths below. If the DB is not present, HUMAnN
// will succeed (and produce the unaligned file) but Kraken2 will fail.
// Set medi_db_path / medi_food_* below to your local paths before running.

includeConfig 'test.config'

process {
    withName: 'profile_function|profile_taxa' {
        cpus = 4 // x2 overprovisioned internally
    }
}

params {
    enable_medi = true
    skipHumann  = false   // required — MEDI needs HUMAnN unmapped reads

    // MEDI DB — S3 Mountpoint: mount-s3 cjb-gutz-s3-demo /home/ubuntu/dbs/
    medi_db_path       = '/home/ubuntu/dbs/referencedata/medi_db'
    medi_food_matches  = '/home/ubuntu/dbs/referencedata/medi_db/food_matches.csv'
    medi_food_contents = '/home/ubuntu/dbs/referencedata/medi_db/food_contents.csv.gz'

    // test.config sets --bypass-translated-search; override it here.
    // MEDI needs the Diamond translated search to produce the unaligned reads file.
    humann_extraparams = ""
}

// Keep work dir so we can inspect *_unaligned.fa.gz after the run
cleanup = false
