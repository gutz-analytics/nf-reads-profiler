// Extends test profile to exercise the MEDI shortcut (I13).
// Run: nextflow run main.nf -profile test_medi
//
// What this tests:
//   1. HUMAnN adds --remove-temp-output false and emits *_unaligned.fa.gz
//   2. Unaligned reads are routed to Kraken2 in MEDI_QUANT (no fastp step)
//
// All DBs served from local SSD scratch (/mnt/scratch/ssddbs), synced from
// s3://cjb-gutz-s3-demo per colin_notes_vm.md section 4.
// nextflow.config binds /mnt/scratch/ssddbs:/mnt/scratch/ssddbs into Docker.
//
// vJan25 available on ssddbs and s3://cjb-gutz-s3-demo/metaphlan_databases/vJan25/.

includeConfig 'test.config'

workDir = '/mnt/scratch/work'
executor {
    queueSize = 20         // Limit the total number of concurrent processes
}
process {
    withName: 'profile_function|profile_taxa' {
        cpus = 4 // x2 overprovisioned internally
    }
}

params {
    input       = "$projectDir/assets/samplesheet-max005-child.csv"
    enable_medi = true
    skipHumann  = false   // required — MEDI needs HUMAnN unmapped reads

    // MetaPhlAn + HUMAnN DBs — local SSD scratch
    direct_metaphlan_id = "mpa_vJan25_CHOCOPhlAnSGB_202503"
    direct_metaphlan_db = "/mnt/scratch/ssddbs/metaphlan_databases/vJan25/"
    humann_metaphlan_id = "mpa_vOct22_CHOCOPhlAnSGB_202403"
    humann_metaphlan_db = "/mnt/scratch/ssddbs/metaphlan_databases/vOct22/"
    humann_chocophlan   = "/mnt/scratch/ssddbs/chocophlan_v4_alpha/"
    humann_uniref       = "/mnt/scratch/ssddbs/uniref90_annotated_v4_alpha_ec_filtered/"
    humann_utilitymap   = "/mnt/scratch/ssddbs/full_mapping_v4_alpha/"

    // MEDI DB — local SSD (not in AMI; provisioned separately on this machine)
    medi_db_path       = '/mnt/scratch/ssddbs/medi_db/'
    medi_food_matches  = '/mnt/scratch/ssddbs/medi_db/food_matches.csv'
    medi_food_contents = '/mnt/scratch/ssddbs/medi_db/food_contents.csv.gz'

    // test.config sets --bypass-translated-search; override it here.
    // MEDI needs the Diamond translated search to produce the unaligned reads file.
    humann_extraparams = ""
}

// Keep work dir so we can inspect *_unaligned.fa.gz after the run
cleanup = false
