workDir = 's3://gutz-nf-reads-profilers-workdir' // stack-managed bucket; 30-day lifecycle rule applied by CFN
cleanup = false

params {
    input    = "s3://gutz-nf-reads-profilers-runs/samplesheets/samplesheet-test-sra.csv"
    outdir   = "s3://gutz-nf-reads-profilers-runs/results/"

    // We have many options on where to put dbs;
    // Here, we run `aws s3 sync` in Launch Template to /mnt/dbs/
    direct_metaphlan_id = "mpa_vJan25_CHOCOPhlAnSGB_202503"
    direct_metaphlan_db = "/mnt/dbs/metaphlan_databases/vJan25/"
    direct_bt2options   = "very-sensitive"
    humann_metaphlan_id = "mpa_vOct22_CHOCOPhlAnSGB_202403"
    humann_metaphlan_db = "/mnt/dbs/metaphlan_databases/vOct22/"
    humann_bt2options   = "very-sensitive"
    humann_chocophlan   = "/mnt/dbs/chocophlan_v4_alpha/"
    humann_uniref       = "/mnt/dbs/uniref90_annotated_v4_alpha_ec_filtered/"
    humann_utilitymap   = "/mnt/dbs/full_mapping_v4_alpha/"
    humann_extraparams  = "" // Like --bypass-translated-search
}

// from https://github.com/nextflow-io/nextflow/issues/1371#issuecomment-587958867
executor {
    submitRateLimit = '10/s'
    queueSize = 200
    // autoThrottle = true
    // poolSize = 8
    // maxPoolSize = 8
    // maxRetries = 50000
    // keepAlive = '1 min'
    // errorBurstDelay = '1 sec'
    // backOffMinRate = 0
    // backOffFactor = 2
    // rampUpInterval = 100
    // rampUpFactor = 1.2
}
process {
    executor = 'awsbatch'
    cache = 'lenient'

    // Lightweight utility processes
    withName: 'get_software_versions' {
        memory = '1 GB'
    }

    // Default: spot instances for most processes
    queue = 'spot-queue'
    cpus = 4
    memory = '32 GB'
    time = '1h'
    maxRetries = 0

    // Global resource caps - prevents runaway memory on retries
    resourceLimits = [
        cpus: 8,
        memory: 64.GB,
        time: 6.h
    ]

    withName: 'profile_function' {
        time   = '6h'
        memory = '60 GB'
        cpus   = 4
    }
}
aws {
    client {
        protocol = 'https'
        // Use S3 Intelligent-Tiering for work directory (auto-optimizes cost)
        uploadStorageClass = 'INTELLIGENT_TIERING'
        maxErrorRetry = 10
        uploadChunkSize = '100MB'
        uploadMaxAttempts = 10
        uploadRetrySleep = '10 sec'
        // maxConnections = 2 // This seems to be closely tied to uploadMaxThreads - vast differences caused issues for me
        // uploadMaxThreads = 2 // Vary this according to your uploader computer
    }

    batch {
        cliPath = '/opt/conda-aws/bin/aws'  // Miniconda-installed awscli; LaunchTemplate user-data puts it here. Nextflow mounts the grandparent dir (/opt/conda-aws) into the container, so the install must be self-contained under that tree.
        jobRole = 'arn:aws:iam::730883236839:role/nf-reads-profiler-batch-job-role'
        maxTransferAttempts = 100
        delayBetweenAttempts = 10
        maxParallelTransfers = 10
        // Bind the local EBS path to the container. See infra/batch-stack.yaml UserData section
        volumes = ['/mnt/dbs:/mnt/dbs']
    }
}
