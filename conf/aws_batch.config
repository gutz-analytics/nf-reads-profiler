// AWS Batch configuration for nf-reads-profiler
// Optimized for cost efficiency with spot/on-demand hybrid strategy
//
// Required AWS Batch infrastructure:
//
//   1. "spot-queue" - Job queue connected to a SPOT compute environment
//      - Allocation strategy: SPOT_CAPACITY_OPTIMIZED
//      - Instance types: r6id.2xlarge, r5d.2xlarge, r7iz.2xlarge, m6id.2xlarge
//        (use 'd' suffix = NVMe instance store for local DB caching)
//      - Min vCPUs: 0, Max vCPUs: 256
//      - Multi-AZ subnets for resilience
//      - Launch template: see "NVMe Database Caching" section below
//
//   2. "ondemand-queue" - Job queue connected to an ON_DEMAND compute environment
//      - Instance types: r6id.2xlarge, r6id.4xlarge
//      - Min vCPUs: 0, Max vCPUs: 64
//      - For long-running HUMAnN jobs that can't tolerate spot eviction
//      - Launch template: see "NVMe Database Caching" section below
//
//   3. "spot-highmem-queue" - Job queue connected to a SPOT high-memory compute environment
//      - Allocation strategy: SPOT_CAPACITY_OPTIMIZED
//      - Instance types: r6id.8xlarge, r5d.8xlarge, i3en.2xlarge
//      - Min vCPUs: 0, Max vCPUs: 128
//      - For Kraken2/MEDI (short-running, high-memory)
//      - Launch template: see "NVMe Database Caching" section below
//
// ---------------------------------------------------------------------------
// NVMe Database Caching (for faster DB load times)
// ---------------------------------------------------------------------------
// All compute environments should use a launch template with the following
// UserData script. This caches databases from S3 to local NVMe SSDs, giving
// ~3-7 GB/s read throughput vs ~100-500 MB/s from EFS.
//
// Launch template UserData (base64-encoded):
//
//   MIME-Version: 1.0
//   Content-Type: multipart/mixed; boundary="==BOUNDARY=="
//
//   --==BOUNDARY==
//   Content-Type: text/x-shellscript; charset="us-ascii"
//
//   #!/bin/bash
//   set -euo pipefail
//
//   # Format and mount NVMe instance store
//   NVME_DEV=$(ls /dev/nvme*n1 2>/dev/null | grep -v nvme0 | head -1)
//   if [ -n "$NVME_DEV" ]; then
//     mkfs.xfs -f "$NVME_DEV"
//     mkdir -p /local/dbs
//     mount "$NVME_DEV" /local/dbs
//     chmod 1777 /local/dbs
//
//     # Sync databases from S3 (runs once at instance startup, shared by all jobs)
//     DB_BUCKET="s3://your-metagenome-dbs-bucket/metagenome-dbs"
//
//     # MetaPhlAn DB (~15 GB, Bowtie2 index)
//     aws s3 sync "$DB_BUCKET/metaphlan/metaphlan4/" /local/dbs/metaphlan/ \
//       --no-progress --only-show-errors &
//
//     # HUMAnN DBs (~35 GB total: ChocoPhlAn + UniRef)
//     aws s3 sync "$DB_BUCKET/humann/4.0/" /local/dbs/humann/ \
//       --no-progress --only-show-errors &
//
//     # Kraken2/MEDI DB (~65 GB)
//     aws s3 sync "$DB_BUCKET/MEDI/medi_db/" /local/dbs/medi_db/ \
//       --no-progress --only-show-errors &
//
//     wait  # All syncs complete before any jobs start
//     echo "Database caching complete: $(du -sh /local/dbs)"
//   fi
//
//   --==BOUNDARY==--
//
// The 'd' instance types (r6id, r5d, m6id, i3en) include NVMe SSDs:
//   r6id.2xlarge:  474 GB NVMe, 8 vCPU, 64 GB RAM  ($0.5022/hr)
//   r6id.4xlarge:  950 GB NVMe, 16 vCPU, 128 GB RAM ($1.0044/hr)
//   r6id.8xlarge: 1900 GB NVMe, 32 vCPU, 256 GB RAM ($2.0088/hr)
//   i3en.2xlarge: 2500 GB NVMe, 8 vCPU, 64 GB RAM   ($0.904/hr)
//
// Cost impact: NVMe instance types cost ~5-10% more than non-NVMe equivalents,
// but database-heavy processes (MetaPhlAn, HUMAnN) run 20-40% faster due to
// eliminated network I/O latency. Net savings: ~15-30% per sample.
// ---------------------------------------------------------------------------

executor {
    submitRateLimit = '20/s'
    queueSize = 200
}

// Override database paths to use local NVMe cache when available.
// The launch template syncs databases from S3 to /local/dbs at instance startup.
// Processes check /local/dbs first, falling back to the default paths (EFS/network).
params {
    local_db_cache = '/local/dbs'
}

process {
    executor = 'awsbatch'
    cache = 'lenient'   // Use lenient caching for S3 (timestamps unreliable)
    cleanup = true

    // Default: spot instances for most processes
    queue = 'spot-queue'
    cpus = 4
    memory = '32 GB'
    time = '4h'
    maxRetries = 3

    // Global resource caps - prevents runaway memory on retries
    resourceLimits = [
        cpus: 32,
        memory: 256.GB,
        time: 48.h
    ]

    // -------------------------------------------------------------------
    // Smart error strategy: distinguish spot evictions from real failures
    // Exit codes 137 (SIGKILL/OOM), 143 (SIGTERM) = infrastructure issues
    // Exit codes 1, 2 = software/data errors
    // -------------------------------------------------------------------
    errorStrategy = {
        if (task.exitStatus in [137, 143, 139]) {
            // Infrastructure failure (spot eviction, OOM, SIGTERM)
            return task.attempt <= 3 ? 'retry' : 'ignore'
        } else if (task.exitStatus == 0) {
            return 'finished'
        } else {
            // Software/data error - retry once in case of transient issue, then give up
            return task.attempt <= 1 ? 'retry' : 'ignore'
        }
    }

    // -------------------------------------------------------------------
    // Data handling processes - spot, small instances
    // -------------------------------------------------------------------
    withName: 'AWS_DOWNLOAD' {
        queue = 'spot-queue'
        cpus = 4
        memory = '16 GB'
        time = '2h'
    }

    withName: 'FASTERQ_DUMP' {
        queue = 'spot-queue'
        cpus = 8
        memory = { 32.GB * task.attempt }
        time = '4h'
        maxRetries = 3
    }

    // -------------------------------------------------------------------
    // QC processes - spot, small instances
    // -------------------------------------------------------------------
    withLabel: 'fastp' {
        queue = 'spot-queue'
        cpus = 4
        memory = '16 GB'
        time = '2h'
    }

    withLabel: 'low' {
        queue = 'spot-queue'
        cpus = 2
        memory = '8 GB'
        time = '2h'
    }

    withName: 'count_reads' {
        queue = 'spot-queue'
        cpus = 2
        memory = '8 GB'
        time = '1h'
    }

    // -------------------------------------------------------------------
    // MetaPhlAn - spot OK (4-5 hour jobs, cheap to retry)
    // Dynamic memory: scales up on OOM retry
    // NVMe caching: Bowtie2 index load drops from ~5min to ~30sec
    // -------------------------------------------------------------------
    withName: 'profile_taxa' {
        queue = 'spot-queue'
        cpus = { 8 * Math.min(task.attempt, 2) }
        memory = { 64.GB * task.attempt }
        time = '6h'
        maxRetries = 2
    }

    // -------------------------------------------------------------------
    // HUMAnN - queue controlled by params.humann_spot
    //   false (default): on-demand queue for guaranteed completion
    //   true: spot queue (70% cheaper, ~5-8% eviction risk on 6hr jobs)
    // At 6hr avg runtime, spot is viable. At 36hr (high read depth), use on-demand.
    //
    // NVMe caching: ChocoPhlAn nucleotide search drops from ~45min to ~15min,
    // UniRef/Diamond protein search I/O reduced by ~30%.
    // -------------------------------------------------------------------
    withName: 'profile_function' {
        queue = { params.humann_spot ? 'spot-queue' : 'ondemand-queue' }
        cpus = 8
        memory = { 64.GB * task.attempt }
        time = { params.humann_spot ? '12h' : '48h' }
        maxRetries = { params.humann_spot ? 3 : 2 }
        errorStrategy = {
            if (task.exitStatus in [137, 143, 139]) {
                // OOM, spot eviction, or SIGTERM - retry with more memory
                return task.attempt <= (params.humann_spot ? 3 : 2) ? 'retry' : 'ignore'
            } else if (task.exitStatus == 0) {
                return 'finished'
            } else {
                // Real software error - on spot, retry once (could be transient);
                // on on-demand, don't waste money retrying
                return params.humann_spot && task.attempt <= 1 ? 'retry' : 'ignore'
            }
        }
    }

    // -------------------------------------------------------------------
    // Kraken2/MEDI - spot OK (short jobs, high memory)
    // Uses dedicated high-memory spot queue for cost savings (~74%)
    // NVMe caching + ramdisk: DB load from NVMe to ramdisk is ~10x faster
    // than from EFS to ramdisk.
    // -------------------------------------------------------------------
    withLabel: 'kraken' {
        queue = 'spot-highmem-queue'
        cpus = 32
        memory = '256 GB'
        time = '4h'
        maxRetries = 3
    }

    // -------------------------------------------------------------------
    // MultiQC - spot, MINIMAL resources (it's just a Python report generator)
    // Previously misconfigured at 64 CPU / 512GB - actual need is ~2 CPU / 4GB
    // -------------------------------------------------------------------
    withName: 'MULTIQC' {
        queue = 'spot-queue'
        cpus = 2
        memory = '4 GB'
        time = '1h'
    }

    withName: 'get_software_versions' {
        queue = 'spot-queue'
        cpus = 1
        memory = '2 GB'
        time = '30m'
    }
}

aws {
    client {
        protocol = 'https'
        // Use S3 Intelligent-Tiering for work directory (auto-optimizes cost)
        uploadStorageClass = 'INTELLIGENT_TIERING'
        maxErrorRetry = 10
        uploadChunkSize = '100MB'
        uploadMaxAttempts = 10
        uploadRetrySleep = '10 sec'
    }

    batch {
        maxTransferAttempts = 10
        delayBetweenAttempts = 10
        maxParallelTransfers = 10
        // Spot retry: AWS Batch retries internally on spot eviction
        // before Nextflow sees a failure. Set to 3 for short tasks.
        maxSpotAttempts = 3
    }
}

// Recommend adding S3 lifecycle policy to your work bucket:
// {
//   "Rules": [{
//     "ID": "cleanup-nextflow-work",
//     "Status": "Enabled",
//     "Filter": { "Prefix": "work/" },
//     "Expiration": { "Days": 14 },
//     "AbortIncompleteMultipartUpload": { "DaysAfterInitiation": 3 }
//   }]
// }
