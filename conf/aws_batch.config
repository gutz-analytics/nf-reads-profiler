workDir = 's3://gutz-nf-reads-profilers-workdir/work' // stack-managed bucket; 30-day lifecycle rule applied by CFN
cleanup = false

params {
    input    = "s3://gutz-nf-reads-profilers-runs/samplesheets/samplesheet-test-sra.csv"
    outdir   = "s3://gutz-nf-reads-profilers-runs/results/"

    // DBs pre-baked into worker AMI at /mnt/dbs/ (see issues/I14)
    // MetaPhlAn
    direct_metaphlan_id = "mpa_vJan25_CHOCOPhlAnSGB_202503"
    direct_metaphlan_db = "/mnt/dbs/metaphlan_databases/vJan25/"
    direct_bt2options   = "very-sensitive"
    // HUMAnN4
    humann_metaphlan_id = "mpa_vOct22_CHOCOPhlAnSGB_202403"
    humann_metaphlan_db = "/mnt/dbs/metaphlan_databases/vOct22/"
    humann_bt2options   = "very-sensitive"
    humann_chocophlan   = "/mnt/dbs/chocophlan_v4_alpha/"
    humann_uniref       = "/mnt/dbs/uniref90_annotated_v4_alpha_ec_filtered/"
    humann_utilitymap   = "/mnt/dbs/full_mapping_v4_alpha/"
    humann_extraparams  = "" // Like --bypass-translated-search

    // MEDI DB — local SSD on runner node (not baked into worker AMI; provisioned separately)
    medi_db_path       = '/mnt/scratch/ssddbs/medi_db/'
    medi_food_matches  = '/mnt/scratch/ssddbs/medi_db/food_matches.csv'
    medi_food_contents = '/mnt/scratch/ssddbs/medi_db/food_contents.csv.gz'
}

// from https://github.com/nextflow-io/nextflow/issues/1371#issuecomment-587958867
executor {
    submitRateLimit = '10/s'
    // Maximum tasks Nextflow keeps in flight across all states (SUBMITTED
    // + RUNNABLE + RUNNING). Acts as a global flow-control cap independent
    // of CE MaxvCpus. Raise toward 1000+ for the >1k sample runs.
    queueSize = 200
    // autoThrottle = true
    // poolSize = 8
    // maxPoolSize = 8
    // Nextflow-side retries for Batch API. Disabled here, avoid double-retry layers.
    // maxRetries = 0
    // keepAlive = '1 min'
    // errorBurstDelay = '1 sec'
    // backOffMinRate = 0
    // backOffFactor = 2
    // rampUpInterval = 100
    // rampUpFactor = 1.2
}
process {
    executor = 'awsbatch'
    cache = 'lenient'

    // Default: spot instances for most processes
    queue = 'spot-queue'
    cpus = 4
    memory = 32.GB
    time = 1.h
    // Retries for all failure modes; spot reclamation, OOM, non-zero exit, timeout. With
    // resourceLimits in place, retries can't escalate past 8 vCPU / 64 GB / 6h.
    // Default errorStrategy when maxRetries > 0 is 'retry'.
    maxRetries = 5

    // Global resource caps - prevents runaway memory on retries
    resourceLimits = [
        cpus: 8,
        memory: 64.GB,
        time: 6.h
    ]

    withName: 'profile_function' {
        time   = 6.h
        memory = 60.GB // peak rss under 20
        cpus   = 4 // x2 internally
    }

    // Downstream combine/split/MultiQC — lightweight aggregation, run on this node
    withName: 'combine_humann_tables|combine_humann_taxonomy_tables|combine_metaphlan_tables' {
        executor = 'local'
    }
    withName: 'split_stratified_tables|convert_tables_to_biom|regroup_genefamilies|MULTIQC|get_software_versions' {
        executor = 'local'
    }

    // MEDI: all processes run on this node — Kraken2 needs the 415 GB DB
    // memory-mapped from local SSD; can't fit in worker AMI.
    // Note: glob 'MEDI_QUANT:*' does not match qualified names in this NF version;
    // processes are listed explicitly.
    withName: 'MEDI_QUANT:kraken|MEDI_QUANT:architeuthis_filter|MEDI_QUANT:kraken_report|MEDI_QUANT:count_taxa' {
        executor = 'local'
    }
    withName: 'MEDI_QUANT:merge_taxonomy|MEDI_QUANT:add_lineage|MEDI_QUANT:quantify|MEDI_QUANT:summarize_mappings|MEDI_QUANT:merge_mappings' {
        executor = 'local'
    }
    withName: 'MEDI_QUANT:convert_medi_to_biom|MEDI_QUANT:multiqc' {
        executor = 'local'
    }
    withName: 'MEDI_QUANT:kraken' {
        executor      = 'local'
        cpus          = 8
        maxForks      = 1
        time          = 30.m
        errorStrategy = { task.attempt < 2 ? 'retry' : 'ignore' }
        maxRetries    = 1
        // Stream hash into Linux page cache before first job; subsequent jobs
        // find it in RAM (~100 GB/s). Cold load ~30 min; warm ~2.5 min/sample.
        beforeScript  = 'cat /mnt/scratch/ssddbs/medi_db/hash.k2d > /dev/null'
    }

    withName: 'profile_taxa' {
        // Standalone MetaPhlAn against vJan25 (~34 GB index). Need more
        // than the 1h default — actual alignment plus on-the-fly DB prep
        // (decompressing .bz2 fasta, joining, bowtie2-build) was ~50 min
        // on the first I16 max005 attempt before timing out.
        // Bake the DB prep into the AMI (see issue I21) to drop most of
        // the setup cost; 3h leaves headroom for the alignment work.
        time   = 1.h
        memory = 38.GB // peak rss under 36
        cpus   = 4 // x2 internally
    }
}
aws {
    client {
        // Use S3 Intelligent-Tiering for work directory (auto-optimizes cost)
        uploadStorageClass = 'INTELLIGENT_TIERING'
        // AWS SDK retry budget for *S3 client* calls (GetObject, PutObject,
        // ListBucket). Covers transient 5xx, throttling, network blips during
        // workdir/output transfers. Independent of process-level retries.
        maxErrorRetry = 10
        uploadChunkSize = 100.MB
        uploadMaxAttempts = 10
        uploadRetrySleep = 10.s
        // maxConnections = 2    // tightly coupled to uploadMaxThreads — large deltas caused issues
        // uploadMaxThreads = 2  // tune per uploader
    }

    batch {
        // Miniconda-installed awscli; LaunchTemplate user-data puts it here.
        // NF mounts the grandparent dir (/opt/conda-aws) into the container —
        // install must be self-contained under that tree.
        cliPath = '/opt/conda-aws/bin/aws'
        jobRole = 'arn:aws:iam::730883236839:role/nf-reads-profiler-batch-job-role'
        // Batch-level retry on spot reclaim ("Host EC2 terminated"). Bypasses Nextflow's
        // process.maxRetries path (which doesn't catch host termination). See issue I19.
        maxSpotAttempts = 5
        maxTransferAttempts = 100
        delayBetweenAttempts = 10.s
        maxParallelTransfers = 10
        // Bind the local EBS path to the container. See infra/batch-stack.yaml UserData section
        volumes = ['/mnt/dbs:/mnt/dbs']
    }
}
