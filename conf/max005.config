// Local run of 5 child gut SRA samples (SRP662258) — used for realistic timing
// comparisons, especially hostile benchmarking. Full nreads, real DBs, no cleanup.
// Run: nextflow run main.nf -profile max005

executor {
    queueSize = 3  // 5 samples; limit to 3 concurrent to avoid OOM on MetaPhlAn (35GB each)
}

process {
    withName: '.*' {
        cpus = 4
        time = 4.h
    }

    // Local Docker only: map container UID/GID to host so output files aren't root-owned.
    withName: 'profile_function|combine_humann_tables|convert_tables_to_biom|split_stratified_tables|regroup_genefamilies' {
        containerOptions = '-u $(id -u):$(id -g)'
    }
}

params {
    input    = "$projectDir/assets/samplesheet-max005-child.csv"
    outdir   = "$projectDir/results_local_logs"
    project  = "max005"

    singleEnd  = false
    mergeReads = false
    skipHostile   = false // skip host removal with https://github.com/bede/hostile
    skipHumann = false
    skipCompleted = false

    nreads   = 0  // no cap — matches previous max005 runs for runtime comparison
    minreads = 100000

    humann_extraparams = "" // Use "--bypass-translated-search" for speed on the next run.


    enable_medi        = false
    medi_db_path       = null
    medi_food_matches  = null
    medi_food_contents = null
}

// Keep reports and work dir for post-run inspection and timing comparison
timeline.enabled = true
report.enabled   = true
trace.enabled    = true
dag.enabled      = false
cleanup          = false
